// =================================================================
//  SCRAPER SUB-PROJECT: FILTERED DOWNLOAD UI
//  File: scraper-download.js
//
//  PASTE THIS AS A NEW JS FILE (or merge into your sub-project's
//  existing module file) inside your main project's /js folder.
//
//  WHAT THIS DOES
//  Builds a jurisdiction dropdown scoped to the LOGGED-IN USER by
//  calling getMyAllowedJurisdictions() — see Code_ScraperJurisdiction.gs.
//  That function reuses _userMatchesSchool() (Code_HR.gs), the same
//  rule your app already uses to filter real data rows, so this
//  dropdown can never show a jurisdiction the user couldn't actually
//  download data for. A user sees a jurisdiction if it matches their
//  PRIMARY fields (District/Wing/Tehsil/Markaz) OR their separately
//  ASSIGNED scope (Scope Type/Value) — it's a union of the two, not
//  an intersection. Then lets the user pick a jurisdiction and
//  download the scraper's results filtered to that selection.
//
//  ASSUMES (matches your existing core.js / admin.js patterns):
//    - `currentUser` is a global already set after login
//    - `google.script.run` shim from api.js is loaded
//    - `showToast(msg, type)` exists (core.js)
//    - HTML has elements with these IDs (create them in your
//      sub-project's HTML section — see markup snippet below):
//        #scrDistrict, #scrWing, #scrTehsil, #scrMarkaz,
//        #scrSchool (only shown if scope is Schools-level),
//        #scrDownloadBtn
// =================================================================

let scrJurisdiction = { districts: [], wings: [], tehsils: [], markazes: [], schools: [], jMap: [] };
let scrJurisdictionLoaded = false;

// ── INIT: call this when the scraper/download view opens ─────────
function initScraperDownloadView() {
  if (scrJurisdictionLoaded) {
    populateScraperDropdowns();
    return;
  }
  showLoadingIfAvailable();
  google.script.run
    .withSuccessHandler(res => {
      hideLoadingIfAvailable();
      if (!res || !res.success) {
        showToast('Could not load your jurisdiction access: ' + (res && res.message || 'Unknown error'), 'error');
        return;
      }
      scrJurisdiction = res;
      scrJurisdictionLoaded = true;
      populateScraperDropdowns();
    })
    .withFailureHandler(err => {
      hideLoadingIfAvailable();
      showToast('Jurisdiction load error: ' + err.message, 'error');
    })
    .getMyAllowedJurisdictions(currentUser);
}

// ── Populate the dropdowns from the scoped data we received ──────
function populateScraperDropdowns() {
  setSelectOptions('scrDistrict', scrJurisdiction.districts, 'All Districts');
  setSelectOptions('scrWing',     scrJurisdiction.wings,     'All Wings');
  setSelectOptions('scrTehsil',   scrJurisdiction.tehsils,   'All Tehsils');
  setSelectOptions('scrMarkaz',   scrJurisdiction.markazes,  'All Markazs');

  // If the user is scoped to specific Schools (not just a hierarchy
  // level), show a school picker instead of/alongside the markaz one.
  const schoolWrap = document.getElementById('scrSchoolWrap');
  if (schoolWrap) {
    const hasSchools = scrJurisdiction.schools && scrJurisdiction.schools.length > 0;
    schoolWrap.style.display = hasSchools ? '' : 'none';
    if (hasSchools) {
      const sel = document.getElementById('scrSchool');
      sel.innerHTML = '<option value="">All Assigned Schools</option>' +
        scrJurisdiction.schools.map(s =>
          `<option value="${escHtmlIfAvailable(s.emis || s.uid)}">${escHtmlIfAvailable(s.name)}</option>`
        ).join('');
    }
  }

  // If the user only has ONE option at a given level (i.e. it's fixed,
  // not really a "choice"), auto-select it and disable that dropdown —
  // this reflects their Primary jurisdiction not being changeable.
  autoSelectIfSingleOption('scrDistrict', scrJurisdiction.districts);
  autoSelectIfSingleOption('scrWing',     scrJurisdiction.wings);
  autoSelectIfSingleOption('scrTehsil',   scrJurisdiction.tehsils);

  document.getElementById('scrDownloadBtn').disabled = false;
}

function autoSelectIfSingleOption(id, values) {
  const el = document.getElementById(id);
  if (!el) return;
  if (values && values.length === 1) {
    el.value = values[0];
    el.disabled = true;
  } else {
    el.disabled = false;
  }
}

function setSelectOptions(id, values, placeholder) {
  const sel = document.getElementById(id);
  if (!sel) return;
  sel.innerHTML = `<option value="">${placeholder}</option>` +
    (values || []).map(v => `<option value="${escHtmlIfAvailable(v)}">${escHtmlIfAvailable(v)}</option>`).join('');
}

// ── Cascading filters: Markaz options narrow as District/Wing/Tehsil change ──
// NOTE: this is pure UI convenience for narrowing the Markaz list as the
// user picks values. It does NOT enforce access control — jMap already
// only contains rows the user is allowed to see (filtered server-side by
// _userMatchesSchool via getMyAllowedJurisdictions). This function can
// only ever narrow further within that already-safe set, never widen it.
function onScraperFilterChange() {
  const d = document.getElementById('scrDistrict').value;
  const w = document.getElementById('scrWing').value;
  const t = document.getElementById('scrTehsil').value;

  const filtered = (scrJurisdiction.jMap || []).filter(item =>
    (!d || item.district === d) &&
    (!w || item.wing === w) &&
    (!t || item.tehsil === t)
  );
  const validMarkazes = [...new Set(filtered.map(i => i.markaz).filter(Boolean))].sort();
  const useFiltered = d || w || t;
  setSelectOptions('scrMarkaz', useFiltered ? validMarkazes : scrJurisdiction.markazes, 'All Markazs');
}

// ── DOWNLOAD: gather the selected filter and request scraped data ──
// Adjust the function name `getScrapedResultsFiltered` to match
// whatever your scraper sub-project's own .gs function is called.
function downloadFilteredScraperResults() {
  const filter = {
    district: document.getElementById('scrDistrict').value || '',
    wing:     document.getElementById('scrWing').value     || '',
    tehsil:   document.getElementById('scrTehsil').value    || '',
    markaz:   document.getElementById('scrMarkaz').value    || '',
    school:   document.getElementById('scrSchool') ? document.getElementById('scrSchool').value : ''
  };

  showLoadingIfAvailable();
  google.script.run
    .withSuccessHandler(res => {
      hideLoadingIfAvailable();
      if (!res || !res.success) {
        showToast('Download failed: ' + (res && res.message || 'Unknown error'), 'error');
        return;
      }
      // Expects { success:true, base64, mimeType, filename } —
      // matching the doExport() pattern already used in core.js.
      const bytes = Uint8Array.from(atob(res.base64), c => c.charCodeAt(0));
      const a = document.createElement('a');
      a.href = URL.createObjectURL(new Blob([bytes], { type: res.mimeType }));
      a.download = res.filename || 'scraped_results.xlsx';
      a.click();
      showToast('Download ready.', 'success');
    })
    .withFailureHandler(err => {
      hideLoadingIfAvailable();
      showToast('Download error: ' + err.message, 'error');
    })
    .getScrapedResultsFiltered(filter, currentUser);
}

// ── Small helpers so this file works even if core.js helpers
//    aren't loaded yet on this view (defensive fallbacks) ──────────
function showLoadingIfAvailable() {
  if (typeof showLoading === 'function') showLoading();
}
function hideLoadingIfAvailable() {
  if (typeof hideLoading === 'function') hideLoading();
}
function escHtmlIfAvailable(v) {
  if (typeof escHtml === 'function') return escHtml(v);
  const div = document.createElement('div');
  div.textContent = v == null ? '' : String(v);
  return div.innerHTML;
}

/* =================================================================
   HTML MARKUP SNIPPET — add this where you want the filter UI
   (e.g. inside your scraper/download view's container):

   <div class="filter-row">
     <select id="scrDistrict" onchange="onScraperFilterChange()"><option>All Districts</option></select>
     <select id="scrWing"     onchange="onScraperFilterChange()"><option>All Wings</option></select>
     <select id="scrTehsil"   onchange="onScraperFilterChange()"><option>All Tehsils</option></select>
     <select id="scrMarkaz"><option>All Markazs</option></select>

     <div id="scrSchoolWrap" style="display:none">
       <select id="scrSchool"><option>All Assigned Schools</option></select>
     </div>

     <button id="scrDownloadBtn" onclick="downloadFilteredScraperResults()" disabled>
       Download Filtered Results
     </button>
   </div>

   And call initScraperDownloadView() when this view/tab is opened,
   the same way openAdminModule() calls loadJurisdictionDropdowns().
================================================================= */
